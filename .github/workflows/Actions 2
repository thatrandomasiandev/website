name: Deploy GitHub Pages from /core
on:
  push:
    branches: [ main ]
  workflow_dispatch:

permissions:
  contents: read
  pages: write
  id-token: write

concurrency:
  group: "pages"
  cancel-in-progress: true

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout
        uses: actions/checkout@v4

      # If you need a build step, add it here (e.g., npm ci && npm run build)

      - name: Upload Pages artifact (core folder)
        uses: actions/upload-pages-artifact@v3
        with:
          path: ./core

      - name: Deploy to GitHub Pages
        id: deployment
        uses: actions/deploy-pages@v4
